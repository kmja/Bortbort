# Loppis Helper — environment variables
# Copy this file to .env.local and fill in real values. .env.local is gitignored.

# ── Tradera Developer API ──────────────────────────────────────────────
# Register an application at https://api.tradera.com/ to obtain these.
# TRADERA_APP_ID is an integer; TRADERA_APP_KEY is the "Service Key".
TRADERA_APP_ID=
TRADERA_APP_KEY=

# Public key for the user token-login flow (from the developer portal).
TRADERA_PUBLIC_KEY=

# Keep the spike on Tradera's sandbox. Set to "false" ONLY when you mean to
# touch the live marketplace. Defaults to sandbox (true) when unset.
TRADERA_SANDBOX=true

# A valid category id to use for the hardcoded test listing. Required before
# POST /api/tradera/test-listing will run. Discover ids via the categories API.
TRADERA_TEST_CATEGORY_ID=

# Optional: skip the interactive token-login flow by providing a user token
# directly (handy for running the AddItem spike from a script).
# TRADERA_USER_ID=
# TRADERA_USER_TOKEN=

# Optional overrides (sensible defaults are used if unset):
# TRADERA_API_BASE_URL=https://api.tradera.com/v3
# TRADERA_TOKEN_LOGIN_URL=https://api.tradera.com/tokenlogin.aspx

# ── Anthropic API (item identification + drafting) ─────────────────────
# Used by POST /api/identify. Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=
# Optional model override (defaults to claude-opus-4-8):
# ANTHROPIC_MODEL=claude-opus-4-8

# ── App ─────────────────────────────────────────────────────────────────
# Base URL of this app, used to build the Tradera token-login return URL.
# On Vercel this is detected automatically; set it for local/custom hosting.
# APP_BASE_URL=http://localhost:3000
