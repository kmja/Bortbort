# Loppis Helper — environment variables
# Copy this file to .env.local and fill in real values. .env.local is gitignored.

# ── Tradera Developer API ──────────────────────────────────────────────
# Register an application at https://api.tradera.com/ to obtain these.
# TRADERA_APP_ID is an integer; TRADERA_APP_KEY is the "App Key" / "Service Key".
# The PRIMARY app (below) is used for the token-login flow + AddItem.
TRADERA_APP_ID=
TRADERA_APP_KEY=

# Public key for the user token-login flow (from the developer portal).
TRADERA_PUBLIC_KEY=

# RATE-LIMIT POOLING (optional): Tradera allows ~100 calls/endpoint/24h PER APP.
# Add more registered apps to multiply read headroom — they're rotated for the
# public read calls (GetOfficialTime, Search/pricing). Add _2, _3, … up to _10.
# TRADERA_APP_ID_2=
# TRADERA_APP_KEY_2=
# TRADERA_PUBLIC_KEY_2=
# TRADERA_APP_ID_3=
# TRADERA_APP_KEY_3=
# TRADERA_PUBLIC_KEY_3=

# Keep the spike on Tradera's sandbox. Set to "false" ONLY when you mean to
# touch the live marketplace. Defaults to sandbox (true) when unset.
TRADERA_SANDBOX=true

# A valid category id to use for the hardcoded test listing. Required before
# POST /api/tradera/test-listing will run. Discover ids via the categories API.
TRADERA_TEST_CATEGORY_ID=

# Optional: skip the interactive token-login flow by providing a user token
# directly (handy for running the AddItem spike from a script).
# TRADERA_USER_ID=
# TRADERA_USER_TOKEN=

# Optional overrides (sensible defaults are used if unset):
# TRADERA_API_BASE_URL=https://api.tradera.com/v3
# TRADERA_TOKEN_LOGIN_URL=https://api.tradera.com/token-login

# ── Gemini API (item identification, batch detection, valuation) ───────
# Used by /api/identify, /api/identify-batch and /api/tradera/value.
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Optional model override. Defaults to the cheap vision model gemini-2.5-flash.
# Use gemini-2.5-pro for higher-quality output at higher cost.
# GEMINI_MODEL=gemini-2.5-flash

# ── App ─────────────────────────────────────────────────────────────────
# Base URL of this app, used to build the Tradera token-login return URL.
# On Vercel this is detected automatically; set it for local/custom hosting.
# APP_BASE_URL=http://localhost:3000
